  "grammarPoints": [
    {
      "title": "～は ～です (肯定句)",
      "description": "這是日語最基本的句型，表示「A 是 B」。\n例：私は 曾(そう)です。(我是曾先生/小姐。)\n注意：這裡的『は』要讀作『wa』。"
    },
    {
      "title": "～は ～じゃありません (否定句)",
      "description": "表示「A 不是 B」。在口語中也可以說『ではありません』。\n例：私は 学生じゃありません。(我不是學生。)"
    },
    {
      "title": "～か (疑問句)",
      "description": "在句尾加上『か』就變成疑問句，相當於中文的『嗎』。\n例：あなたは エンジニアですか。(你是工程師嗎？)"
    },
    {
      "title": "～も (也)",
      "description": "當主詞的情況與前述相同時，用『も』取代『は』。\n例：私も 台湾人です。(我也是台灣人。)"
    }
  ],
  "quiz": [
